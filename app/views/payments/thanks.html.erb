<section class="breadcrumb">
  <div class="container">
    <div class="row">
      <div class="col-12">
        <h2 class="text-center color-white mb-0 text-uppercase"></h2>
        <a href="javascript:window.location.href='/'" class="btnvoltar float-right"><img class="f-voltar" src="/site/assets/professores/<%= @site %>/img/icons/arrow-prev.svg" alt="voltar">VOLTAR</a>
      </div>
    </div>
  </div>
</section>
<% if @payment.status == "paid" %>
  <div class="courseint mt-5 ppage">
    <div class="container"  style="max-width: 835px; transition: margin 200ms;">
      <div class="col contact-form pt-3 pb-3 pl-4 pr-4">
        <div class="card mb-4">
          <div class="card-body">
            <div class="text-center mb-4">
              <h2>Compra Realizada com Sucesso</h2>
            </div>
            <p>
              Olá <b class="font-weight-bold"><%= @user.name %></b>, 
              <span>
                nos próximos minutos você receberá um email em <%= @user.email %> com os dados para poder acessar este
                produto sempre que desejar. Caso não encontre o email, verifique também em sua caixa de SPAM.
              </span>
            </p>
            <div class="text-center mt-5">
              <h5>O código da sua transação é:</h5>
              <input type="text" name="texto" id="texto" class="form-control text-center" value="<%= @payment.code %>" style="width: 100%" readonly/>
            </div>
            <div class="mt-5">
              <% user_courses = @payment.user_courses.non_nil_amount.order(amount: :asc)  %>
              <% user_courses.each do |user_course| %>
                <% course = user_course.course %>
                <hr>
                <div class="row">
                  <div class="col-md-3">
                    <%= image_tag course.image, class: "img-fluid", alt: "#{course.title}" %>
                  </div>
                  <div class="col-md-6">
                    <a class="color-secondary" href="/courses/<%= course.slug %>">
                      <h5><%= course.title %></h5>
                    </a>
                    <div class="infotime" style="padding: 0px;">
                      <% if course.supplementary_material.present? %>
                        <div class="pdf">
                          <img src="/site/assets/professores/<%= @site %>/img/icons/ico-pdf.svg" alt="Downloads Pdf">
                          <span><%= course.supplementary_material %></span>
                        </div>
                      <% end %>
                      <% if course.duration.present? %>
                        <div class="hour">
                          <img src="/site/assets/professores/<%= @site %>/img/icons/ico-video.svg" alt="Horas de Aula">
                          <span><%= course.duration %></span>
                        </div>
                      <% end %>
                    </div>
                  </div>
                  <div class="col-md-3" style="text-align: end;">
                    <h5>
                      <b><%= number_to_currency(user_course.amount, unit: "R$") %></b>
                    </h5>
                  </div>
                </div>
              <% end %>
            </div>
            <div class="mt-5 pt-4 border-top">
              <h6 class="text-uppercase text-muted mb-3" style="font-size: 0.8rem; letter-spacing: .05em;">Resumo do pagamento</h6>
              <div class="row">
                <div class="col-md-6 col-lg-12">
                  <table class="table table-sm table-borderless mb-0">
                    <tbody>
                      <tr>
                        <td class="text-muted">Forma de pagamento</td>
                        <td class="text-right font-weight-bold"><%= @payment.method_pt %></td>
                      </tr>
                      <% if @payment.installments.present? && @payment.installments.to_i > 1 %>
                        <tr>
                          <td class="text-muted">Parcelas</td>
                          <td class="text-right font-weight-bold"><%= @payment.installments %>x</td>
                        </tr>
                      <% end %>
                      <tr>
                        <td class="text-muted">Subtotal (cursos)</td>
                        <td class="text-right">
                          <%= number_to_currency(@payment.user_courses.non_nil_amount.map(&:amount).sum, unit: "R$ ", separator: ",", delimiter: ".") %>
                        </td>
                      </tr>
                      <% if @payment.discount.present? && @payment.discount.to_s.strip != "" %>
                        <tr>
                          <td class="text-muted">Desconto</td>
                          <td class="text-right text-success"><%= @payment.discount %></td>
                        </tr>
                      <% end %>
                      <% if @payment.cashback_applied_cents.to_i.positive? %>
                        <tr>
                          <td class="text-muted">Cashback utilizado</td>
                          <td class="text-right text-success">
                            <%= number_to_currency(@payment.cashback_applied_cents / 100.0, unit: "R$ ", separator: ",", delimiter: ".") %>
                          </td>
                        </tr>
                      <% end %>
                      <% value_tax =  @payment.user_courses.non_nil_amount.map(&:amount).sum - (@payment.cashback_applied_cents.to_f / 100) - (@payment.amount.to_f / 100) %>
                      <% if @payment.method == "card" && value_tax.to_f.negative? %>
                        <tr>
                          <td class="text-muted">Taxas</td>
                          <td class="text-right text-danger">
                            <%= number_to_currency((value_tax * -1), unit: "R$ ", separator: ",", delimiter: ".") %>
                          </td>
                        </tr>
                      <% end %>
                      <tr class="border-top">
                        <td class="text-muted pt-2">Total pago</td>
                        <td class="text-right font-weight-bold pt-2" style="font-size: 1.1rem;">
                          <%= number_to_currency((@payment.amount.to_f / 100), unit: "R$ ", separator: ",", delimiter: ".") %>
                        </td>
                      </tr>
                    </tbody>
                  </table>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
<% elsif @payment.status == "expired" %>
  <div class="courseint mt-5 ppage">
    <div class="container" style="max-width: 835px; transition: margin 200ms;">
      <div class="col contact-form pt-3 pb-3 pl-4 pr-4">
        <div class="card mb-4">
          <div class="card-body">
            <div class="text-center mb-4">
              <h2> <%= @payment.method == "billet" ? "Boleto" : "Pix" %> Vencido</h2>
            </div>
            <p>
              Olá <b class="font-weight-bold"><%= @user.name %></b>,
              <span>
                O seu <%= @payment.method == "billet" ? "boleto" : "pix" %> venceu devido à falta de pagamento. Para garantir o acesso aos cursos, entre em contato com nossa equipe para que possamos emitir um novo boleto o mais rápido possível. Estamos aqui para ajudar!
              </span>
            </p>
          </div>
        </div>
      </div>
    </div>
  </div>
<% elsif @payment.method == "billet" %>
  <%= render "payments/messages/billet", payment: @payment, user: @user %>
<% elsif @payment.method == "pix" %>
  <%= render "payments/messages/pix", payment: @payment, user: @user %>
<% end %>
