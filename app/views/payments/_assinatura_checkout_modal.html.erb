<% assinatura_slug = HomeController::COMPARISON_SLUG_ASSINATURA %>
<% swap_url = "/cart/new?course=#{assinatura_slug}&clear_cart=true" %>
<% upsell_video = @company.video_upsell %>

<div class="modal fade checkout-assinatura-modal" id="modalAssinaturaCheckout" tabindex="-1" role="dialog" aria-labelledby="modalAssinaturaCheckoutTitle" aria-hidden="true" data-backdrop="static" data-keyboard="false">
  <div class="modal-dialog modal-dialog-centered checkout-assinatura-modal__dialog" role="document">
    <div class="modal-content checkout-assinatura-modal__content">
      <div class="checkout-assinatura-modal__grid">
        <%# Mobile: mídia em destaque no topo (vídeo ou capa) + título do pacote %>
        <div class="checkout-assinatura-modal__hero-mobile d-md-none">
          <div class="checkout-assinatura-modal__hero-media">
            <% if upsell_video.present? %>
              <div class="checkout-assinatura-modal__video-embed checkout-assinatura-modal__video-embed--hero">
                <iframe
                  src="<%= upsell_video %>?rel=0"
                  title="Vídeo da assinatura Rani Passos"
                  loading="lazy"
                  allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                  allowfullscreen></iframe>
              </div>
            <% else %>
              <div class="checkout-assinatura-modal__hero-cover">
                <% if @assinatura_course.image.attached? %>
                  <%= image_tag @assinatura_course.image,
                        class: "checkout-assinatura-modal__hero-cover-img",
                        alt: @assinatura_course.title %>
                <% else %>
                  <%= image_tag "/site/assets/#{@site}/img/assinatura.jpg",
                        class: "checkout-assinatura-modal__hero-cover-img",
                        alt: @assinatura_course.title %>
                <% end %>
              </div>
            <% end %>
          </div>
          <div class="checkout-assinatura-modal__hero-meta">
            <span class="checkout-assinatura-modal__visual-kicker checkout-assinatura-modal__hero-kicker">
              <i class="fas fa-layer-group" aria-hidden="true"></i>
              Pacote completo
            </span>
            <p class="checkout-assinatura-modal__visual-title checkout-assinatura-modal__hero-title"><%= @assinatura_course.title %></p>
          </div>
        </div>

        <%# Desktop: coluna visual com capa + “O que inclui” sobreposta %>
        <aside class="checkout-assinatura-modal__visual d-none d-md-block">
          <% if @assinatura_course.image.attached? %>
            <%= image_tag @assinatura_course.image,
                  class: "checkout-assinatura-modal__cover-img",
                  alt: @assinatura_course.title %>
          <% else %>
            <%= image_tag "/site/assets/#{@site}/img/assinatura.jpg",
                  class: "checkout-assinatura-modal__cover-img",
                  alt: @assinatura_course.title %>
          <% end %>
          <div class="checkout-assinatura-modal__visual-scrim" aria-hidden="true"></div>
          <div class="checkout-assinatura-modal__visual-includes">
            <%= render "assinatura_modal_includes" %>
          </div>
          <div class="checkout-assinatura-modal__visual-caption">
            <span class="checkout-assinatura-modal__visual-kicker">
              <i class="fas fa-layer-group" aria-hidden="true"></i>
              Pacote completo
            </span>
            <p class="checkout-assinatura-modal__visual-title"><%= @assinatura_course.title %></p>
          </div>
        </aside>

        <div class="checkout-assinatura-modal__panel">
          <button type="button" class="close checkout-assinatura-modal__close" data-dismiss="modal" aria-label="Fechar">
            <span aria-hidden="true">&times;</span>
          </button>

          <div class="checkout-assinatura-modal__panel-body">
            <span class="checkout-assinatura-modal__badge">
              <i class="fas fa-bolt" aria-hidden="true"></i>
              Oferta especial no checkout
            </span>
            <h2 class="checkout-assinatura-modal__title" id="modalAssinaturaCheckoutTitle">
              Que tal a <strong>Assinatura Rani Passos</strong>?
            </h2>
            <p class="checkout-assinatura-modal__lead">
              Seu pedido atual fica abaixo do investimento da assinatura integral.
              Ao trocar, você garante o acesso completo ao método — e não precisa preencher tudo de novo.
            </p>

            <div class="checkout-assinatura-modal__compare" role="group" aria-label="Comparativo de valores">
              <div class="checkout-assinatura-modal__compare-card">
                <span class="checkout-assinatura-modal__compare-label">Seu pedido agora</span>
                <span class="checkout-assinatura-modal__compare-value"><%= number_to_currency(@total_amount) %></span>
              </div>
              <div class="checkout-assinatura-modal__compare-arrow" aria-hidden="true">
                <i class="fas fa-long-arrow-alt-right"></i>
              </div>
              <div class="checkout-assinatura-modal__compare-card checkout-assinatura-modal__compare-card--featured">
                <span class="checkout-assinatura-modal__compare-label">Assinatura completa</span>
                <span class="checkout-assinatura-modal__compare-value"><%= number_to_currency(@assinatura_floor_price) %></span>
                <span class="checkout-assinatura-modal__compare-hint">Pacote integral de estudos</span>
              </div>
            </div>

            <%# Mobile: “O que inclui” no fluxo do painel (abaixo do comparativo) %>
            <section class="checkout-assinatura-modal__includes-panel d-md-none" aria-label="O que inclui na assinatura">
              <%= render "assinatura_modal_includes" %>
            </section>

            <%# Desktop: vídeo ou capa no painel (duplica mídia só em telas maiores) %>
            <div class="checkout-assinatura-modal__preview d-none d-md-block" aria-label="Apresentação da assinatura">
              <% if upsell_video.present? %>
                <div class="checkout-assinatura-modal__video-embed">
                  <iframe
                    src="<%= upsell_video %>?rel=0"
                    title="Vídeo da assinatura Rani Passos"
                    loading="lazy"
                    allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                    allowfullscreen></iframe>
                </div>
              <% else %>
                <div class="checkout-assinatura-modal__cover-fallback">
                  <% if @assinatura_course.image.attached? %>
                    <%= image_tag @assinatura_course.image,
                          class: "checkout-assinatura-modal__cover-fallback-img",
                          alt: @assinatura_course.title %>
                  <% else %>
                    <%= image_tag "/site/assets/#{@site}/img/assinatura.jpg",
                          class: "checkout-assinatura-modal__cover-fallback-img",
                          alt: @assinatura_course.title %>
                  <% end %>
                </div>
              <% end %>
            </div>
          </div>

          <div class="checkout-assinatura-modal__actions">
            <button type="button" class="btn btn-outline-secondary btn-lg btn-block mb-2 mb-sm-0" id="btnManterCursoCheckout">
              Manter meu pedido atual
            </button>
            <button type="button"
                    class="btn btn-primary btn-lg btn-block checkout-assinatura-modal__cta"
                    id="btnTrocarAssinaturaCheckout"
                    data-swap-url="<%= swap_url %>">
              <span class="checkout-assinatura-modal__cta-label">
                <i class="fas fa-arrow-right mr-1" aria-hidden="true"></i>
                Trocar para a assinatura
              </span>
              <span class="checkout-assinatura-modal__cta-sub">Seus dados serão mantidos</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<input type="hidden" id="checkout_assinatura_floor" value="<%= @assinatura_floor_price %>">
