<form action="/payments" autocomplete="off" method="post" id="payments" accept-charset="utf-8">   
  <div class="d-none">
    <input type="text" name="user_id" id="user_id" value="<%= @user.id %>">
    <input type="text" name="method" id="method">
    <input type="text" name="token" id="token">
    <input type="text" name="installments" id="installments">
    <input type="text" name="discount" id="discount">
    <input type="text" name="credit_card" id="credit_card">
    <input type="text" name="cashback_applied" id="cashback_applied">
    <button type="submit" id="btnformcomprar">Comprar agora</button>
  </div>
</form>
<div class="dados-pagamento">
  <div id="payment-method">
    <ul class="nav nav-pills mb-3" id="pills-tab" role="tablist">
      <li class="nav-item">
        <a class="nav-link active" id="pills-card-tab"  data-toggle="pill" data-payment-method="card" href="#pills-card" role="tab" aria-controls="pills-card" aria-selected="true" data-action="click->payment#setValueImutable">Cartão de Crédito</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" id="pills-billet-tab" data-toggle="pill" data-payment-method="billet" href="#pills-billet" role="tab" aria-controls="pills-billet" aria-selected="false" data-action="click->payment#setValueImutable">Boleto</a>
      </li>
      <li class="nav-item">
        <a class="nav-link" id="pills-pix-tab" data-toggle="pill" data-payment-method="pix" href="#pills-pix" role="tab" aria-controls="pills-pix" aria-selected="false" data-action="click->payment#setValueImutable">Pix</a>
      </li>
    </ul>
    <div class="tab-content mb-4" id="pills-tabContent">
      <%= render "payments/shared/payment_methods"%>
    </div>
  </div>
  <div class="form-group text-center">
    <button onclick="$('#btnformcomprar').click()" class="btn btn-primary btn-contact-send btn-payment-send" id="btncomprar">Comprar agora</button>
  </div>
  <div style="font-size: .7rem;">
    *O valor parcelado possui acréscimo.
  </div>
</div>
