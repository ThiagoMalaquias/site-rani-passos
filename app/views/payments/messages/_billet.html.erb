<div class="checkout-wrap checkout-wrap-billet">
  <section class="checkout-hero checkout-hero-compact">
    <div class="checkout-overlay"></div>

    <div class="container">
      <div class="checkout-hero-head text-center">
        <span class="checkout-top-badge">Pagamento pendente</span>
        <h1 class="checkout-title text-uppercase">Boleto gerado com sucesso</h1>
        <hr class="hero-divider mx-auto">

        <p class="checkout-subtitle">
          Olá, <strong><%= user.name %></strong>. Sua compra foi registrada.
          Agora basta realizar o pagamento do boleto até
          <strong><%= payment.billet_expiry_date.strftime("%d/%m/%Y") %></strong>.
        </p>
      </div>

      <div class="row">
        <div class="col-lg-7 mb-4">
          <div class="checkout-panel">
            <div class="checkout-panel-header">
              <h3>Dados do boleto</h3>
              <p>Use a linha digitável ou visualize o boleto completo para pagamento.</p>
            </div>

            <div class="checkout-panel-body">
              <div class="checkout-section mb-4">
                <div class="checkout-section-title no-number">
                  <h4>Linha digitável</h4>
                </div>

                <div class="billet-code-box">
                  <input
                    type="text"
                    id="texto"
                    class="form-control checkout-input text-center font-weight-bold"
                    value="<%= payment.billet_line %>"
                    readonly
                  >
                  <button type="button" class="btn btn-primary billet-copy-btn" onclick="copiarTexto()">
                    Copiar código
                  </button>
                </div>
              </div>

              <div class="checkout-section mb-4">
                <div class="checkout-section-title no-number">
                  <h4>Código de barras</h4>
                </div>

                <div class="billet-barcode-box text-center">
                  <img src="<%= payment.billet_barcode %>" alt="Código de barras do boleto" class="img-fluid billet-barcode-image" />
                </div>
              </div>

              <div class="checkout-section mb-4">
                <div class="checkout-section-title no-number">
                  <h4>Ações rápidas</h4>
                </div>

                <div class="billet-actions">
                  <a
                    id="viewBillet"
                    target="_blank"
                    class="btn btn-outline-primary billet-action-btn"
                    href="<%= payment.billet_pdf %>"
                  >
                    Visualizar boleto
                  </a>

                  <button
                    type="button"
                    class="btn btn-primary billet-action-btn"
                    onclick="copiarTexto()"
                  >
                    Copiar código
                  </button>
                </div>
              </div>

              <div class="checkout-section mb-4">
                <div class="checkout-section-title no-number">
                  <h4>Informações importantes</h4>
                </div>

                <div class="billet-alert-list">
                  <div class="billet-alert-item billet-alert-warning">
                    <strong>Prazo de compensação</strong>
                    <p>Após o pagamento, a compensação pode levar até 3 dias úteis.</p>
                  </div>

                  <div class="billet-alert-item">
                    <strong>Liberação do acesso</strong>
                    <p>Assim que o pagamento for confirmado, seus dados de acesso serão enviados por e-mail.</p>
                  </div>

                  <div class="billet-alert-item">
                    <strong>Não recebeu o acesso?</strong>
                    <p>
                      Se já se passaram mais de 72 horas após o pagamento, entre em contato com o responsável pela venda.
                    </p>
                  </div>

                  <div class="billet-alert-item">
                    <strong>Verifique o spam</strong>
                    <p>
                      Em alguns casos, os e-mails com os dados de acesso podem cair na caixa de spam.
                    </p>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <div class="col-lg-5 mb-4">
          <aside class="checkout-sidebar">
            <div class="checkout-sidebar-card billet-sidebar-card">
              <span class="checkout-sidebar-badge">Resumo do pagamento</span>

              <div class="billet-status-card">
                <div class="billet-status-icon">⌛</div>
                <h4>Aguardando pagamento</h4>
                <p>
                  Seu boleto está pronto. Realize o pagamento até a data de vencimento para liberar seu acesso.
                </p>
              </div>

              <div class="billet-summary">
                <div class="billet-summary-row">
                  <span>Status</span>
                  <strong class="status-pending">Pendente</strong>
                </div>

                <div class="billet-summary-row">
                  <span>Vencimento</span>
                  <strong><%= payment.billet_expiry_date.strftime("%d/%m/%Y") %></strong>
                </div>

                <div class="billet-summary-row">
                  <span>Forma de pagamento</span>
                  <strong>Boleto bancário</strong>
                </div>

                <div class="billet-summary-row billet-summary-row-total">
                  <span>Total</span>
                  <strong><%= number_to_currency((payment.amount.to_f / 100), unit: "R$ ", separator: ",", delimiter: ".") %></strong>
                </div>
              </div>

              <div class="billet-timer-box">
                <small>Atualização automática do status</small>
                <div id="timer" class="billet-timer">15:00</div>
              </div>

              <div class="billet-sidebar-help">
                <h5>Como pagar</h5>
                <ul>
                  <li>Internet banking</li>
                  <li>Aplicativo do banco</li>
                  <li>Casa lotérica</li>
                  <li>Agência bancária</li>
                </ul>
              </div>

              <a
                href="<%= payment.billet_pdf %>"
                target="_blank"
                class="btn-primary-lg checkout-submit text-center d-block"
              >
                Abrir boleto
              </a>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </section>
</div>

<div class="toast-container position-fixed top-0 end-0 p-3">
  <div id="liveToast" class="toast" role="alert" aria-live="assertive" aria-atomic="true">
    <div class="toast-header">
      <strong class="mr-auto">Aviso</strong>
      <button type="button" class="btn-close" data-bs-dismiss="toast" aria-label="Close"></button>
    </div>
    <div class="toast-body">
      Código copiado com sucesso.
    </div>
  </div>
</div>
<script>
  let tempo;
  let intervalTime;

  window.onload = function () {
    let duration = 60 * 15; // Converter para segundos
    display = document.querySelector('#timer'); // selecionando o timer
    startTimer(duration, display); // iniciando o timer
    verificaPagamento()
  };

  function startTimer(duration, display) {
    var timer = duration, minutes, seconds;

    setInterval(() => {
      minutes = parseInt(timer / 60, 10);
      seconds = parseInt(timer % 60, 10);
      minutes = minutes < 10 ? "0" + minutes : minutes;
      seconds = seconds < 10 ? "0" + seconds : seconds;
      display.textContent = minutes + ":" + seconds;
      if (--timer < 0) {
          timer = duration;
      }else if(timer == 0){
        window.location.assign(`/`);
      }
    }, 1000);
  }


  function verificaPagamento(){
    const code = "<%= payment.code %>"
    clearInterval(intervalTime)

    intervalTime = setInterval(async () => {
      let res = await fetch(`/payments/1.json?code=${code}`, {
        method: 'GET',
        headers: { 'Content-type': 'application/json; charset=UTF-8' }
      })

      const payment = JSON.parse(await res.text());
      if(payment.status == 'paid'){
        window.location.assign(`/payments/thanks/${code}`);
      }
    }, 15000)
  }


  function copiarTexto() {
    let textoCopiado = document.getElementById("texto");
    textoCopiado.select();
    textoCopiado.setSelectionRange(0, 99999)
    document.execCommand("copy");
  }

  const toastTrigger = document.getElementById('liveToastBtn')
  const toastLiveExample = document.getElementById('liveToast')
  if (toastTrigger) {
    toastTrigger.addEventListener('click', () => {
      const toast = new bootstrap.Toast(toastLiveExample)
      toast.show()
    })
  }
</script>
