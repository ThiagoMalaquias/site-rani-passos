<%= render "shared/headerbundle", title: "Depoimentos" %>
<div class="depoimentint ppage">
  <div class="container">
    <div class="row">
      <div class="col-12 mt-5">
        <% medium = @medias.find_by(nature: 'banner') %>
        <% if medium.present? %>
          <%= image_tag medium.banner, alt: "Banner", class: "bantopdepo" %>
        <% end %>
      </div>
      <div class="col-12 mt-5">
        <% @testimonials.each do |testimonial| %>
          <div class="depouser">
            <div class="imgdepo">
              <%= image_tag testimonial.photo, alt: "Depoimento de #{testimonial.name}" %>
            </div>
            <div class="depoinfo d-flex flex-column justify-content-center">
              <div class="namedepo">
                <h3><%= testimonial.name %></h3>
              </div>
              <div class="depdepo">
                <span><%= testimonial.position %></span>
              </div>
              <div class="instadepo">
                <span><img class="icodepoinst" src="/site/assets/professores/<%= @site %>/img/icons/ico-instagram.svg" alt=""><a target="_blank" href="https://www.instagram.com/<%= testimonial.instagram %>">@<%= testimonial.instagram %></a></span>
              </div>
            </div>
            <div class="textdepo d-flex flex-column justify-content-center text-center">
              <p></p>
              <%= testimonial.text %>
              <p></p>
            </div>
          </div>
        <% end %>
      </div>
      <div class="col-12 dep-videos mt-5">
        <% @medias.where.not(nature: 'banner').each do |media| %>
          <div class="flex-column align-items-center d-flex" data-slick-index="-3" id="" aria-hidden="true" style="width: 370px;" tabindex="-1">
            <iframe src="<%= media.url %>" title="YouTube video player" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" allowfullscreen=""></iframe>
          </div>
        <% end %>
      </div>
    </div>
  </div>
</div>
<script>
  $(function() {
      $(".dep-videos").slick({
          dots: false,
          infinite: !0,
          speed: 250,
          arrows: true,
          slidesToShow: 3,
          slidesToScroll: 1,
          responsive: [{
              breakpoint: 1200,
              settings: {
                  slidesToShow: 3,
                  slidesToScroll: 1,
                  infinite: !0,
                  dots: !0
              }
          }, {
              breakpoint: 769,
              settings: {
                  arrows: !1,
                  slidesToShow: 2,
                  slidesToScroll: 1
              }
          }, {
              breakpoint: 500,
              settings: {
                  arrows: !1,
                  slidesToShow: 1,
                  slidesToScroll: 1
              }
          }]
      })
  })
</script>
