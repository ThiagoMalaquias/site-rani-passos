<div class="checkout-wrap" data-controller="payment">
  <% main_course = @courses.first %>
  <% default_installment = @all_installments.last %>
  <section class="checkout-hero">
    <div class="checkout-overlay"></div>
    <div class="container">
      <div class="checkout-hero-head text-center">
        <span class="checkout-top-badge">Matrícula segura e 100% online</span>
        <h1 class="checkout-title text-uppercase">Finalizar matrícula</h1>
        <hr class="hero-divider mx-auto">
        <p class="checkout-subtitle">
          Você está a um passo de garantir seu acesso aos cursos
          Preencha seus dados e escolha a melhor forma de pagamento.
        </p>
      </div>
      <form action="/payments" autocomplete="off" method="post" id="payments" accept-charset="utf-8">
        <div class="row">
          <!-- ESQUERDA -->
          <div class="col-lg-7 mb-4">
            <div class="checkout-panel">
              <div class="checkout-panel-header">
                <h3>Seus dados</h3>
                <p>Preencha as informações abaixo para concluir sua matrícula.</p>
              </div>
              <div class="checkout-panel-body">
                <div class="checkout-section">
                  <div class="checkout-section-title">
                    <span class="checkout-section-number">01</span>
                    <h4>Informações pessoais</h4>
                  </div>
                  <div class="form-row">
                    <div class="form-group col-md-12">
                      <label for="name">Nome completo</label>
                      <input type="text"
                             class="form-control checkout-input"
                             name="user[name]"
                             id="name"
                             value="<%= @user.name rescue '' %>"
                             placeholder="Ex: José da Silva"
                             required>
                    </div>
                    <div class="form-group col-md-6">
                      <label for="email">E-mail</label>
                      <input type="email"
                             class="form-control checkout-input"
                             name="user[email]"
                             id="email"
                             value="<%= @user.email rescue '' %>"
                             placeholder="seuemail@exemplo.com"
                             required>
                    </div>
                    <div class="form-group col-md-6">
                      <label for="confirm_email">Confirme seu e-mail</label>
                      <input type="email"
                             class="form-control checkout-input"
                             name="user[confirm_email]"
                             id="confirm_email"
                             value="<%= @user.email rescue '' %>"
                             placeholder="Repita seu e-mail"
                             required>
                    </div>
                    <div class="form-group col-md-6">
                      <label for="phone">Telefone</label>
                      <input type="text"
                             class="form-control checkout-input"
                             name="user[phone]"
                             id="phone"
                             value="<%= @user.phone rescue '' %>"
                             placeholder="(00) 91234-5678"
                             required>
                    </div>
                    <div class="form-group col-md-6">
                      <label for="cpf">CPF</label>
                      <input type="text"
                             class="form-control checkout-input"
                             name="user[cpf]"
                             id="cpf"
                             value="<%= @user.cpf rescue '' %>"
                             placeholder="000.000.000-00"
                             required>
                    </div>

                    <div class="form-group col-md-3">
                      <label for="cep">CEP</label>
                      <input type="text"
                             class="form-control checkout-input"
                             name="address[posta_code]"
                             id="cep"
                             value="<%= @user.addresses.first.posta_code rescue '' %>"
                             placeholder="00000-000"
                             required>
                    </div>
                    <div class="form-group col-md-7">
                      <label for="street">Endereço</label>
                      <input type="text"
                             class="form-control checkout-input"
                             name="address[street]"
                             id="street"
                             value="<%= @user.addresses.first.street rescue '' %>"
                             placeholder="Rua, avenida, etc."
                             required>
                    </div>
                    <div class="form-group col-md-2">
                      <label for="number">Nº</label>
                      <input type="text"
                             class="form-control checkout-input"
                             name="address[number]"
                             id="number"
                             value="<%= @user.addresses.first.number rescue '' %>"
                             placeholder="123"
                             required>
                    </div>
                    <div class="form-group col-md-5 d-none">
                      <label for="complement">Complemento</label>
                      <input type="text"
                             class="form-control checkout-input"
                             name="address[complement]"
                             id="complement"
                             value="<%= @user.addresses.first.complement rescue '' %>"
                             placeholder="Apto, bloco, casa...">
                    </div>
                    <div class="form-group col-md-4 d-none">
                      <label for="neighborhood">Bairro</label>
                      <input type="text"
                             class="form-control checkout-input"
                             name="address[neighborhood]"
                             id="neighborhood"
                             value="<%= @user.addresses.first.neighborhood rescue '' %>"
                             required>
                    </div>
                    <div class="form-group col-md-8 d-none">
                      <label for="city">Cidade</label>
                      <input type="text"
                             class="form-control checkout-input"
                             name="address[city]"
                             id="city"
                             value="<%= @user.addresses.first.city rescue '' %>"
                             required>
                    </div>
                    <div class="form-group col-md-4 d-none">
                      <label for="uf">UF</label>
                      <input type="text"
                             class="form-control checkout-input text-uppercase"
                             name="address[uf]"
                             id="uf"
                             value="<%= @user.addresses.first.uf rescue '' %>"
                             maxlength="2"
                             placeholder="SP"
                             required>
                    </div>
                  </div>
                </div>
                <div class="checkout-section">
                  <div class="checkout-section-title">
                    <span class="checkout-section-number">02</span>
                    <h4>Forma de pagamento</h4>
                  </div>
                  <div class="checkout-payment-box">
                    <div id="payment-method">
                      <ul class="nav nav-pills checkout-payment-tabs mb-4" id="pills-tab" role="tablist">
                        <li class="nav-item">
                          <a class="nav-link active"
                             id="pills-card-tab"
                             data-toggle="pill"
                             data-payment-method="card"
                             href="#pills-card"
                             role="tab"
                             aria-controls="pills-card"
                             aria-selected="true"
                             data-action="click->payment#setValueImutable">
                            <span>💳</span>
                            Cartão
                          </a>
                        </li>
                        <li class="nav-item">
                          <a class="nav-link"
                             id="pills-billet-tab"
                             data-toggle="pill"
                             data-payment-method="billet"
                             href="#pills-billet"
                             role="tab"
                             aria-controls="pills-billet"
                             aria-selected="false"
                             data-action="click->payment#setValueImutable">
                            <span>📄</span>
                            Boleto
                          </a>
                        </li>
                        <li class="nav-item">
                          <a class="nav-link"
                             id="pills-pix-tab"
                             data-toggle="pill"
                             data-payment-method="pix"
                             href="#pills-pix"
                             role="tab"
                             aria-controls="pills-pix"
                             aria-selected="false"
                             data-action="click->payment#setValueImutable">
                            <span>⚡</span>
                            Pix
                          </a>
                        </li>
                      </ul>
                      <div class="tab-content" id="pills-tabContent">
                        <!-- CARTÃO -->
                        <div class="tab-pane fade show active" id="pills-card" role="tabpanel" aria-labelledby="pills-card-tab">
                          <div class="checkout-method-card">
                            <div class="row">
                              <div class="col-md-12">
                                <div class="form-group">
                                  <label for="cnumber">Número do cartão</label>
                                  <input type="tel"
                                         class="form-control checkout-input"
                                         name="card[number]"
                                         id="cnumber"
                                         placeholder="0000 0000 0000 0000">
                                </div>
                                <div class="form-group">
                                  <label for="cname">Nome impresso no cartão</label>
                                  <input type="text"
                                         class="form-control checkout-input"
                                         name="card[name]"
                                         id="cname"
                                         placeholder="Nome como está no cartão">
                                </div>
                                <div class="form-row">
                                  <div class="form-group col-7">
                                    <label for="cexpiry">Validade</label>
                                    <input type="tel"
                                           class="form-control checkout-input"
                                           name="card[expiry]"
                                           id="cexpiry"
                                           placeholder="MM/AA">
                                  </div>
                                  <div class="form-group col-5">
                                    <label for="ccvc">CVC</label>
                                    <input type="tel"
                                           class="form-control checkout-input"
                                           name="card[cvc]"
                                           id="ccvc"
                                           placeholder="123">
                                  </div>
                                </div>
                                <div class="form-group mb-0">
                                  <label for="installment">Parcelamento</label>
                                  <select class="form-control checkout-input"
                                          name="installments"
                                          id="installment"
                                          data-action="change->payment#setInstallment">
                                    <% @all_installments.each do |installment| %>
                                      <option value="<%= installment[:key] %>"
                                              data-js-installment-value="<%= installment[:value] %>"
                                              <%= "selected" if default_installment.present? && installment[:key] == default_installment[:key] %>>
                                        <% if installment[:key] < 7 %>
                                          <%= "#{installment[:key]}x de #{number_to_currency(installment[:value])}" %>
                                        <% else %>
                                          <%= "#{installment[:key]}x de #{number_to_currency(installment[:value])}*" %>
                                        <% end %>
                                      </option>
                                    <% end %>
                                  </select>
                                  <small class="checkout-note">*Parcelas maiores podem ter acréscimo.</small>
                                </div>
                              </div>
                            </div>
                          </div>
                        </div>
                        <!-- BOLETO -->
                        <div class="tab-pane fade" id="pills-billet" role="tabpanel" aria-labelledby="pills-billet-tab">
                          <div class="checkout-method-info-grid">
                            <div class="checkout-method-info">
                              <h5>Pagamento por boleto</h5>
                              <p>Após finalizar, o boleto será gerado para pagamento.</p>
                            </div>
                            <div class="checkout-method-info">
                              <h5>Prazo de compensação</h5>
                              <p>O boleto pode levar até 3 dias úteis para ser compensado.</p>
                            </div>
                            <div class="checkout-method-info">
                              <h5>Liberação do acesso</h5>
                              <p>Seu acesso é liberado após a confirmação bancária.</p>
                            </div>
                          </div>
                        </div>
                        <!-- PIX -->
                        <div class="tab-pane fade" id="pills-pix" role="tabpanel" aria-labelledby="pills-pix-tab">
                          <div class="checkout-method-info-grid">
                            <div class="checkout-method-info featured">
                              <h5>Pix instantâneo</h5>
                              <p>Pagamento rápido, simples e com confirmação em poucos segundos.</p>
                            </div>
                            <div class="checkout-method-info">
                              <h5>QR Code ou copia e cola</h5>
                              <p>Você poderá pagar com o app do seu banco em poucos toques.</p>
                            </div>
                            <div class="checkout-method-info">
                              <h5>Acesso mais rápido</h5>
                              <p>Após a confirmação do Pix, sua matrícula pode ser liberada rapidamente.</p>
                            </div>
                          </div>
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
                <!-- HIDDEN FIELDS -->
                <input type="hidden" name="user_id" id="user_id" value="">
                <input type="hidden" name="method" id="method" value="card">
                <input type="hidden" name="token" id="token">
                <input type="hidden" name="cashback_applied" id="cashback_applied">
                <input type="hidden" id="checkout_full_total_amount" value="<%= @total_amount.to_f %>">
              </div>
            </div>
          </div>
          <!-- DIREITA -->
          <div class="col-lg-5 mb-4">
            <aside class="checkout-sidebar <%= 'checkout-sidebar--sticky' unless @sugestions.present? %>">
              <div class="checkout-sidebar-card">
                <span class="checkout-sidebar-badge">Resumo da matrícula</span>
                <div class="checkout-courses-list">
                  <% @courses.each do |course| %>
                    <% cart_line = @cookies_course.find { |c| c["id"].to_i == course.id } %>
                    <% d_title = cart_line.present? ? course.checkout_discount_title(cart_line) : nil %>
                    <% d_amount = cart_line.present? ? course.checkout_discount_amount(cart_line) : 0.0 %>
                    <div class="checkout-course-card">
                      <% if course.image.attached? %>
                        <%= image_tag course.image,
                              class: "checkout-course-thumb",
                              alt: course.title %>
                      <% else %>
                        <%= image_tag "/site/assets/#{@site}/img/assinatura.jpg",
                              class: "checkout-course-thumb",
                              alt: course.title %>
                      <% end %>
                      <div class="checkout-course-info">
                        <h4><%= course.title %></h4>
                        <span class="checkout-course-access">
                          <%= course.lifetime ? "Acesso vitalício" : "#{course.period_access} meses de acesso" %>
                        </span>
                        <% if @courses.many? %>
                          <span class="checkout-course-line-total">
                            <%= number_to_currency(course.total_price(cart_line || {})) %>
                          </span>
                        <% end %>
                        <% if d_title.present? && d_amount.positive? %>
                          <span class="checkout-flag checkout-flag--name"><%= d_title %></span>
                          <span class="checkout-flag checkout-flag--value">− <%= number_to_currency(d_amount) %></span>
                        <% end %>
                      </div>
                    </div>
                  <% end %>
                </div>
               
                <div class="checkout-price-box">
                  <small>Total da compra</small>
                  <strong id="total_amount">
                    <% if default_installment.present? %>
                      <%= "#{default_installment[:key]}x de #{number_to_currency(default_installment[:value])}" %><%= "*" if default_installment[:key] >= 7 %>
                    <% else %>
                      <%= number_to_currency(@total_amount) %>
                    <% end %>
                  </strong>
                  <span>Pagamento seguro e ambiente criptografado</span>
                </div>
                <div class="mb-4 text-center">
                  <img src="/site/assets/professores/ranipassos/img/site-seguro-100.png" alt="" class="img-fluid" style="width: 70%;">
                </div>
                <button type="submit"
                        class="btn-primary-lg checkout-submit pulse"
                        id="btncomprar">
                  Confirmar compra
                </button>
                <p class="checkout-bottom-note">
                  Ao finalizar, você concorda com os termos da compra e política da plataforma.
                </p>
              </div>
              <% if @sugestions.present? %>
                <div class="checkout-sidebar-upsell">
                  <%= render "checkout_upsell", sidebar_mode: true %>
                </div>
              <% end %>
            </aside>
            
          </div>
        </div>
      </form>

      <div class="hero-guarantee">
        <div>
          <img src="/site/assets/professores/<%= @site %>/img/cartao.png" alt="">
          <span>Cartão <br> de crédito</span>
        </div>
        <div>
          <img src="/site/assets/professores/<%= @site %>/img/boleto.png" alt="">
          <span>Boleto</span>
        </div>
        <div>
          <img src="/site/assets/professores/<%= @site %>/img/pix.png" alt="">
          <span>Pix</span>
        </div>
        <div>
          <img src="/site/assets/professores/<%= @site %>/img/compra-segura.png" alt="">
          <span><strong>Compra</strong> <br> 100% segura</span>
        </div>
        <div>
          <img src="/site/assets/professores/<%= @site %>/img/privacidade-protegida.png" alt="">
          <span>Privacidade <br> protegida</span>
        </div>
      </div>
    </div>
  </section>
</div>

<% if @show_assinatura_checkout_modal %>
  <%= render "assinatura_checkout_modal" %>
<% end %>

<script>
  window.checkoutAssinaturaUpsell = <%= @show_assinatura_checkout_modal ? "true" : "false" %>;

  (function () {
    var DRAFT_KEY = 'rp_checkout_form_draft_v1';
    var SKIP_NAMES = ['authenticity_token', 'utf8', 'checkout_full_total_amount'];

    window.saveCheckoutFormDraftAndGo = function (url) {
      var form = document.getElementById('payments');
      if (!form || !url) {
        window.location.href = url;
        return;
      }
      var data = {};
      $(form).find('input, select, textarea').each(function () {
        var el = this;
        var name = el.name;
        if (!name) return;
        var type = (el.type || '').toLowerCase();
        if (type === 'submit' || type === 'button') return;
        if (SKIP_NAMES.indexOf(name) >= 0) return;
        if (name === '_method') return;
        data[name] = $(el).val();
      });
      try {
        sessionStorage.setItem(DRAFT_KEY, JSON.stringify(data));
      } catch (err) {}
      window.location.href = url;
    };

    window.restoreCheckoutFormDraftIfAny = function () {
      var raw;
      try {
        raw = sessionStorage.getItem(DRAFT_KEY);
      } catch (err) {
        return;
      }
      if (!raw) return;
      try {
        sessionStorage.removeItem(DRAFT_KEY);
        var data = JSON.parse(raw);
        var form = document.getElementById('payments');
        if (!form) return;
        $.each(data, function (name, value) {
          if (value === undefined || value === null) return;
          if (SKIP_NAMES.indexOf(name) >= 0) return;
          $(form).find('[name]').filter(function () {
            return this.name === name;
          }).val(value);
        });
        var method = ($('#method').val() || 'card').toString();
        if (method === 'billet' && $('#pills-billet-tab').length) {
          $('#pills-billet-tab').tab('show');
        } else if (method === 'pix' && $('#pills-pix-tab').length) {
          $('#pills-pix-tab').tab('show');
        } else if ($('#pills-card-tab').length) {
          $('#pills-card-tab').tab('show');
        }
      } catch (err) {}
    };
  })();

  $(document).ready(function () {
    restoreCheckoutFormDraftIfAny();

    $('#cnumber').mask('0000 0000 0000 0000');
    $('#cexpiry').mask('00/00');
    $('#ccvc').mask('000');
    $('#phone').mask('(00) 00000-0000');
    $('#cpf').mask('000.000.000-00');
    $('#cep').mask('00000-000');

    function formatBRL(value) {
      return value.toLocaleString('pt-BR', {
        style: 'currency',
        currency: 'BRL'
      });
    }

    function updateCheckoutTotalFromInstallments() {
      var $sel = $('#installment');
      var $opt = $sel.find('option:selected');
      var count = parseInt($sel.val(), 10) || 1;
      var perInstallment = parseFloat($opt.data('js-installment-value'));
      if (isNaN(perInstallment)) perInstallment = 0;
      var label = count + 'x de ' + formatBRL(perInstallment);
      if (count >= 7) label += '*';
      $('#total_amount').text(label);
    }

    function setTotalAmountForCashPayment() {
      var full = parseFloat($('#checkout_full_total_amount').val(), 10);
      if (isNaN(full)) full = 0;
      $('#total_amount').text(formatBRL(full));
    }

    $('#pills-tab').on('click', 'a[data-payment-method]', function () {
      var method = $(this).data('payment-method');
      if (method) {
        $('#method').val(method);
      }
      if (method === 'billet' || method === 'pix') {
        setTotalAmountForCashPayment();
      } else if (method === 'card') {
        updateCheckoutTotalFromInstallments();
      }
    });

    $('#cep').on('change', function () {
      var cep = $(this).val();
      if (cep.length == 9) {
        $.ajax({
          type: "GET",
          url: `https://viacep.com.br/ws/${cep}/json/`,
          success: function(data){
            console.log(data);
            $('#street').val(data.logradouro);
            $('#neighborhood').val(data.bairro);
            $('#city').val(data.localidade);
            $('#uf').val(data.uf);
            $('#number').focus();
          }
        });
      }
    });

    $('#installment').on('change', updateCheckoutTotalFromInstallments);

    var payMethod = ($('#method').val() || 'card').toString();
    if (payMethod === 'billet' || payMethod === 'pix') {
      setTotalAmountForCashPayment();
    } else {
      updateCheckoutTotalFromInstallments();
    }

    var skipAssinaturaModal = false;

    $('#payments').on('submit', function (e) {
      if (!window.checkoutAssinaturaUpsell) return;
      if (skipAssinaturaModal) return;
      var total = parseFloat($('#checkout_full_total_amount').val(), 10);
      if (isNaN(total)) total = 0;
      var floor = parseFloat($('#checkout_assinatura_floor').val(), 10);
      if (isNaN(floor)) floor = 0;
      if (total >= floor - 0.01) return;
      e.preventDefault();
      e.stopImmediatePropagation();
      $('#modalAssinaturaCheckout').modal('show');
    });

    $('#btnManterCursoCheckout').on('click', function () {
      skipAssinaturaModal = true;
      $('#modalAssinaturaCheckout').modal('hide');
      setTimeout(function () {
        $('#payments')[0].submit();
      }, 200);
    });

    $(document).on('click', '#btnTrocarAssinaturaCheckout', function () {
      var url = $(this).data('swap-url');
      if (url) {
        saveCheckoutFormDraftAndGo(url);
      }
    });
  });
</script>