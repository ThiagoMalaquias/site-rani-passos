<div class="landing-wrap">
  <div class="landing-promotion">
    <span>Desconto por pouco tempo. <strong>APROVEITE AGORA MESMO!</strong></span>
  </div>

  <div class="landing-hero">
    <div class="landing-overlay"></div>
    <div class="container hero-grid">
      <div class="hero-text">
        <h1 class="hero-title text-uppercase color-white"><%= @course.title %></h1>
        <hr class="hero-divider">
        <p class="hero-subtitle">
        Durante 13 anos, construímos algo que vai além de simples videoaulas: somos uma marca reconhecida por entregar muito além do que prometemos. Enquanto alguns apenas ensinam, nós elevamos a régua. Enquanto a mercado repete fórmulas, nós aplicamos métodos e geramos resultados. Enquanto outros falam em aprovação, nós formamos aprovados - inclusive os primeiros colocados.
        </p>

        <div class="hero-features">
          <div class="feature">
            <img src="/site/assets/professores/<%= @site %>/img/video.png" alt="Videoaulas" class="mb-2 img-fluid ">
            <div class="mt-2">
              <strong>Videoaulas</strong>
              <span class="mt-3">Curso teórico completo do básico ao avançado.</span>
            </div>
          </div>
          <div class="feature">
            <img src="/site/assets/professores/<%= @site %>/img/pdf.png" alt="Materiais" class="mb-2 img-fluid">
            <div class="mt-2">
              <strong>Materiais</strong>
              <span class="mt-3">PDFs estratégicos para um estudo eficiente e direcionado.</span>
            </div>
          </div>
          <div class="feature">
            <img src="/site/assets/professores/<%= @site %>/img/rav.png" alt="RAV" class="mb-2 img-fluid">
            <div class="mt-2">
              <strong>RAV</strong>
              <span class="mt-3">I.A. treinada para concurso público e focada na sua banca.</span>
            </div>
          </div>
        </div>
      </div>

      <div class="hero-media">
        <div class="media-card">
          <% if @course.url.present? %>
            <iframe src="<%= @course.url %>" frameborder="0" allowfullscreen></iframe>

            <div class="media-badge">
              <img src="/site/assets/professores/<%= @site %>/img/icons/ico-play.svg" alt="">
              Aula de apresentação gratuita
            </div>
          <% elsif @course.image.attached? %>
            <%= image_tag @course.image, class: "hero-image", alt: @course.title %>
          <% else %>
            <%= image_tag "/site/assets/#{@site}/img/assinatura.jpg", class: "hero-image", alt: @course.title %>
          <% end %>
        </div>

        <ul class="hero-stats">
          <li>
            <strong><%= @course.lesson_count || "120+" %></strong>
            Aulas completas
          </li>
          <li>
            <strong><%= @course.lifetime ? "Vitalício" : "#{@course.period_access} meses" %></strong>
            Acesso garantido
          </li>
        </ul>

        <div class="hero-buttons">
          <% if @course.nature == "free" %>
            <a href="/user_courses/new?course=<%= @course.slug %>" class="btn-primary-lg pulse">Começar agora grátis</a>
          <% elsif @course.link_hotmart.present? %>
            <a href="<%= @course.link_hotmart %>" class="btn-primary-lg pulse" target="_blank">Garantir minha vaga</a>
          <% elsif @course.recurrent %>
            <a href="/subscriptions/new?course=<%= @course.slug %>" class="btn-primary-lg pulse">Assinar agora</a>
          <% else %>
            <% if exist_in_cart?(@site, @course.id) %>
              <a href="/cart" class="btn-primary-lg pulse">Ir para o carrinho</a>
            <% else %>
              <a href="/cart/new?course=<%= @course.slug %>&discount=<%= params[:discount]%>" class="btn-primary-lg pulse">Clique aqui para comprar</a>
            <% end %>
          <% end %>
        </div>

        <div class="hero-guarantee">
          <div>
            <img src="/site/assets/professores/<%= @site %>/img/cartao.png" alt="">
            <span>Cartão <br> de crédito</span>
          </div>
          <div>
            <img src="/site/assets/professores/<%= @site %>/img/boleto.png" alt="">
            <span>Boleto</span>
          </div>
          <div>
            <img src="/site/assets/professores/<%= @site %>/img/pix.png" alt="">
            <span>Pix</span>
          </div>
          <div>
            <img src="/site/assets/professores/<%= @site %>/img/compra-segura.png" alt="">
            <span><strong>Compra</strong> <br> 100% segura</span>
          </div>
          <div>
            <img src="/site/assets/professores/<%= @site %>/img/privacidade-protegida.png" alt="">
            <span>Privacidade <br> protegida</span>
          </div>
        </div>
      </div>
    </div>

    <div class="hero-stars">
      <img src="/site/assets/professores/<%= @site %>/img/5_estrelas.png" alt="" class="img-fluid">
    </div>
  </div>

  <div class="landing-ribbon">
    <span>Reunimos <span style="color: #fff;">ABSOLUTAMENTE TUDO</span> que você precisa para se <span style="color: #fff;">APROVADO</span>. Seja você avançado ou iniciante nos estudos.</span>
  </div>

  <div class="courseint landing-main">
    <div class="container">
      <div class="row">
        <div class="col-lg-8">
          <% if @course.supplementary_material.present? || @course.duration.present? %>
            <div class="stats-banner">
              <% if @course.duration.present? %>
                <div class="stats-item">
                  <span>Duração total</span>
                  <strong><%= @course.duration %></strong>
                </div>
              <% end %>
              <% if @course.supplementary_material.present? %>
                <div class="stats-item">
                  <span>Materiais extras</span>
                  <strong><%= @course.supplementary_material %></strong>
                </div>
              <% end %>
              <div class="stats-item">
                <span>Estudo flexível</span>
                <strong>Computador + Mobile</strong>
              </div>
            </div>
          <% end %>

          <section class="course-description">
            <%== @course.description %>
          </section>
        </div>

        <div class="col-lg-4">
          <aside class="landing-sidebar">
            <% if @course.nature == "paid" %>
              <%== sidebar_price(@course, params[:discount]) %>
            <% end %>

            <% if @course.link_hotmart.present? %>
              <a href="<%= @course.link_hotmart %>" target="_blank" class="buynow text-uppercase color-white">
                <span class="d-block"><%= @course.nature == "free" ? "Acessar" : "Comprar" %> Agora <img class="coursecart" src="/site/assets/professores/<%= @site %>/img/icons/ico-cart.svg" alt="carrinho"></span>
              </a>
            <% elsif @course.nature == "free" %>
              <a href="/user_courses/new?course=<%= @course.slug %>" class="buynow text-uppercase color-white">
                <span class="d-block">Acessar Agora <img class="coursecart" src="/site/assets/professores/<%= @site %>/img/icons/ico-cart.svg" alt="carrinho"></span>
              </a>
            <% elsif @course.recurrent %>
              <a href="/subscriptions/new?course=<%= @course.slug %>" class="buynow text-uppercase color-white">
                <span class="d-block">Comprar Agora</span>
              </a>
            <% else %>
              <% if exist_in_cart?(@site, @course.id) %>
                <a href="/cart" class="buynow text-uppercase color-white">
                  <span class="d-block">Ir para o Carrinho</span>
                </a>
              <% else %>
                <a href="/cart/new?course=<%= @course.slug %>&discount=<%= params[:discount]%>" class="buynow text-uppercase color-white">
                  <span class="d-block">Adicionar ao Carrinho</span>
                </a>
              <% end %>
            <% end %>

            <ul class="sidebar-list">
              <% @course.warranties.each do |warranty| %>
                <li>
                  <span><%= warranty.title %></span>
                </li>
              <% end %>
              <li><span><%= @course.lifetime ? "Acesso Vitalício" : "#{@course.period_access} meses de acesso" %></span></li>
            </ul>

            <hr class="hero-divider">

            <div class="sidebar-testimony">
            <% testimonial = @testimonials.last %>
              <%= image_tag testimonial.photo, alt: "Depoimento de #{testimonial.name}" %>
              <p><%= testimonial.text %></p>
              <span>- <%= testimonial.name %></span>
            </div>
          </aside>
        </div>
      </div>
    </div>
  </div>

  <div class="container">
    <section class="testimonials enhanced">
      <div class="testimonial-slider">
        <% @testimonials.limit(4).each do |testimonial| %>
          <div>
            <article class="testimonial-item">
              <img src="/site/assets/professores/<%= @site %>/img/icons/ico-stars.svg" alt="" class="stars mb-3">
              <div class="testimonial-header">
                <%= image_tag testimonial.photo, alt: "Depoimento de #{testimonial.name}" %>
                <div>
                  <h4><%= testimonial.name %></h4>
                  <span><%= testimonial.position %></span>
                </div>
              </div>
              <p><%= testimonial.text %></p>
            </article>
          </div>
        <% end %>
      </div>
    </section>
  </div>

  <% unless @course.signature %>
    <div class="container mt-5">
      <h2 class="journey-title-with-lines">
        <span class="title-line"></span>
        <span class="title-text">Disciplina e conteúdo programático</span>
        <span class="title-line"></span>
      </h2>
      <section class="course-matters-section">
        <div class="matters-grid">
          <% @course.matters.active.order(title: :asc).each do |matter| %>
            <div class="matter-card">
              <div class="matter-instructor-photo">
                <% if matter.instructor&.avatar&.attached? %>
                  <%= image_tag matter.instructor.avatar, alt: matter.instructor.name, class: "instructor-image" %>
                <% else %>
                  <div class="instructor-placeholder">
                    <span><%= matter.instructor&.name&.first(2)&.upcase || "?" %></span>
                  </div>
                <% end %>
              </div>
              <div class="matter-content">
                <h3 class="matter-name"><%= matter.title %></h3>
                <% if matter.instructor %>
                  <p class="instructor-name"><%= matter.instructor.name %></p>
                <% end %>
              <hr class="matter-hr">
                <% if matter.capsules.any? %>
                  <% 
                    total_capsules = matter.capsules.count
                    total_lessons = matter.capsules.sum { |c| c.lessons.count }
                    total_videos = matter.capsules.sum do |capsule|
                      capsule.lessons.sum do |lesson|
                        lesson.videos.count + lesson.lesson_lecture_videos.count
                      end
                    end
                    total_pdfs = matter.capsules.sum { |c| c.lessons.sum { |l| l.lesson_content.count } }
                  %>
                  <ul class="matter-content-list">
                    <li>
                      <%= pluralize(total_capsules, "módulo", "módulos") %>
                    </li>
                    <li>
                      <%= pluralize(total_lessons, "aula") %>
                    </li>
                    <li>
                      <%= pluralize(total_videos, "vídeo") %>
                    </li>
                    <li>
                      <%= pluralize(total_pdfs, "PDF") %>
                    </li>
                  </ul>
                  
                <% end %>
              </div>
              <% if matter.capsules.any? %>
              <button type="button" class="btn-view-content" data-toggle="modal" data-target="#matterModal<%= matter.id %>">
                Clique aqui para ver o conteúdo programático
              </button>
              <% end %>
            </div>
          <% end %>
        </div>
      </section>
    </div>
  <% end %>

  <div class="container mt-5">
    <section class="journey-line">
      <h2 class="journey-title-with-lines">
        <span class="title-line"></span>
        <span class="title-text text-center">Plataforma única e 100% direcionada <br> para concurso público</span>
        <span class="title-line"></span>
      </h2>
      <div class="journey-steps">
        <div class="journey-step">
          <span class="step-number">01</span>
          <h4>Área do Aluno Voltada para Concursos</h4>
          <p>Sabemos que o ambiente certo transforma o aprendizado. Nossa plataforma, criada exclusivamente para concursos, oferece uma experiência única que te diferencia da concorrência.</p>
        </div>
        <div class="journey-step">
          <span class="step-number">02</span>
          <h4>Eleito o Melhor Curso do Brasil</h4>
          <p>O professor Rani Passos é reconhecido hà anos como líder em aprovação. El agora, com um time completo você terá acesso a videoaulas do básico ao avançado, PDFs de teoria e revisão, questões comentadas, simulados e muito mais.</p>
        </div>
        <div class="journey-step">
          <span class="step-number">03</span>
          <h4>Inteligência Artificial de Verdade</h4>
          <p>Desde 2022, somos os pioneiros no Brasil com uma lA que estuda milhares de questões de prova - feita para te ensinar exatamente como as bancas cobram. Estamos em constante treinamento e aprendizado.</p>
        </div>
        <div class="journey-step">
          <span class="step-number">04</span>
          <h4>Método de Ensino que Funciona</h4>
          <p>Nossos professores não gravam apenas videoaulas e escrevem PDFs. Eles se preocupam com cada segundo do vídeo e linha escrita para te entregar um método de ensino que realmente funciona e te leva a aprovação.</p>
        </div>
      </div>
    </section>
  </div>

  <%= render "chosen_projects_students", courses: @courses %>

  <div class="final-banner">
    <div class="banner-card">
      <h2 class="text-white">FALE AGORA MESMO COM O NOSSO TIME DE ESPECIALISTAS</h2>
      <p class="text-white">Todos os nossos consultores são especialistas em concursos públicos e estão altamente treinados para te instruir da melhor forma e te ajudar a escolher o melhor projeto para você garantir sua aprovação.</p>
      <a href="https://ranipassos.live/GbiGZ" class="btn-secondary-lg pulse" target="_blank">
        Chamar no whatsapp
      </a>
      <div class="text-center mt-3">
        <img src="/site/assets/professores/<%= @site %>/img/5_estrelas.png" alt="" class="my-2 img-fluid" onclick="window.location.href='/testimonials'" style="cursor: pointer; width: 60%;">
      </div>
    </div>
  </div>

  <!-- Modals for Matter Content -->
  <% @course.matters.active.order(title: :asc).each do |matter| %>
    <div class="modal fade" id="matterModal<%= matter.id %>" tabindex="-1" role="dialog" aria-labelledby="matterModalLabel<%= matter.id %>" aria-hidden="true">
      <div class="modal-dialog modal-lg" role="document">
        <div class="modal-content">
          <div class="modal-header">
            <h5 class="modal-title" id="matterModalLabel<%= matter.id %>">
              <%= matter.title %> - Conteúdo Programático
            </h5>
            <button type="button" class="close" data-dismiss="modal" aria-label="Close">
              <span aria-hidden="true">&times;</span>
            </button>
          </div>
          <div class="modal-body">
            <% matter.capsules.order(order_sequences: :asc).each_with_index do |capsule, index| %>
              <div class="modal-capsule">
                <button class="capsule-toggle collapsed" type="button" data-toggle="collapse" data-target="#capsuleCollapse<%= matter.id %>_<%= index %>" aria-expanded="false" aria-controls="capsuleCollapse<%= matter.id %>_<%= index %>">
                  <h6 class="capsule-title">
                    <span class="capsule-number"><%= index + 1 %></span>
                    <%= capsule.name %>
                    <% if capsule.lessons.any? %>
                      <span class="toggle-icon">+</span>
                    <% else %>
                      <span class="toggle-icon"></span>
                    <% end %>
                  </h6>
                </button>
                <% if capsule.lessons.any? %>
                  <div class="collapse" id="capsuleCollapse<%= matter.id %>_<%= index %>">
                    <ul class="modal-lessons-list">
                      <% capsule.lessons.order(order_sequences: :asc).each do |lesson| %>
                        <li class="modal-lesson-item">
                          <span class="lesson-title"><%= lesson.title %></span>
                          <div class="lesson-meta-items">
                            <% lesson_videos_count = lesson.videos.count + lesson.lesson_lecture_videos.count %>
                            <% if lesson_videos_count > 0 %>
                              <span class="meta-badge videos">
                                <%= pluralize(lesson_videos_count, "vídeo") %>
                              </span>
                            <% end %>
                            <% if lesson.lesson_content.any? %>
                              <span class="meta-badge pdfs">
                                <%= pluralize(lesson.lesson_content.count, "PDF") %>
                              </span>
                            <% end %>
                          </div>
                        </li>
                      <% end %>
                    </ul>
                  </div>
                <% end %>
              </div>
            <% end %>
          </div>
          <div class="modal-footer">
            <button type="button" class="btn btn-secondary" data-dismiss="modal">Fechar</button>
          </div>
        </div>
      </div>
    </div>
  <% end %>
</div>
  <script>
    $(document).ready(function() {
      $(".testimonial-slider").slick({
        dots: false,
        infinite: true,
        speed: 300,
        slidesToShow: 1,
        slidesToScroll: 1,
        autoplay: true,
        autoplaySpeed: 5000,
        arrows: true,
        responsive: [{
          breakpoint: 1200,
          settings: {
            slidesToShow: 2,
            slidesToScroll: 1,
            infinite: true,
            dots: false
          }
        }, {
          breakpoint: 768,
          settings: {
            slidesToShow: 1,
            slidesToScroll: 1,
            arrows: true,
            dots: false
          }
        }, {
          breakpoint: 480,
          settings: {
            slidesToShow: 1,
            slidesToScroll: 1,
            arrows: false,
            dots: false
          }
        }]
      });
    });
  </script>
